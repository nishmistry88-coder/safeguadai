{
  "expo": {
    "name": "SafeGuard AI",
    "slug": "safeguard-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "safeguard",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.safeguard.ai",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SafeGuard needs your location to share with emergency contacts during SOS.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "SafeGuard needs background location access to track your journey and alert contacts if needed.",
        "NSLocationAlwaysUsageDescription": "SafeGuard needs background location access for Going Out Mode safety features.",
        "NSMicrophoneUsageDescription": "SafeGuard needs microphone access for voice activation and threat detection.",
        "UIBackgroundModes": ["location", "fetch", "remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#09090b"
      },
      "package": "com.safeguard.ai",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "RECORD_AUDIO",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SafeGuard needs your location to share with emergency contacts during emergencies.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ef4444"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "SafeGuard needs microphone access for voice activation and threat detection features."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "safeguard-ai"
      }
    }
  }
}
